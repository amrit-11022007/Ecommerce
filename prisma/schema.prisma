datasource db {
  provider = "mysql"
}
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

model Cart {
  cart_id     Int         @id @default(autoincrement())
  customer_id Int
  created_at  DateTime?   @default(now()) @db.Timestamp(0)
  updated_at  DateTime?   @default(now()) @db.Timestamp(0)
  Customers   Customers   @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction, map: "Cart_ibfk_1")
  CartItems   CartItems[]

  @@index([customer_id], map: "customer_id")
}

model CartItems {
  cart_item_id Int       @id @default(autoincrement())
  cart_id      Int
  product_id   Int
  quantity     Int
  price        Decimal   @db.Decimal(10, 2)
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @default(now()) @db.Timestamp(0)
  Cart         Cart      @relation(fields: [cart_id], references: [cart_id], onDelete: Cascade, onUpdate: NoAction, map: "CartItems_ibfk_1")
  Products     Products  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "CartItems_ibfk_2")

  @@unique([cart_id, product_id], map: "cart_id")
  @@index([product_id], map: "product_id")
}

model Customer_address {
  address_id  Int           @id @default(autoincrement())
  customer_id Int?
  city        String        @db.VarChar(50)
  state       String        @db.VarChar(50)
  country     String        @db.VarChar(45)
  created_at  DateTime?     @default(now()) @db.Timestamp(0)
  updated_at  DateTime?     @default(now()) @db.Timestamp(0)
  Customers   Customers?    @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction, map: "Customer_address_ibfk_1")
  Fulfillment Fulfillment[]

  @@index([customer_id], map: "customer_id")
}

model Customers {
  customer_id      Int                @id @default(autoincrement())
  customer_name    String             @db.VarChar(40)
  mobile_number    String             @unique(map: "mobile_number") @db.Char(15)
  created_at       DateTime?          @default(now()) @db.Timestamp(0)
  updated_at       DateTime?          @default(now()) @db.Timestamp(0)
  Cart             Cart[]
  Customer_address Customer_address[]
  Orders           Orders[]
  Reviews          Reviews[]
  Users            Users[]
}

model Fulfillment {
  shipment_id      Int                @id @default(autoincrement())
  order_id         Int
  address_id       Int
  status           Fulfillment_status
  shipment_date    DateTime           @db.Date
  created_at       DateTime?          @default(now()) @db.Timestamp(0)
  updated_at       DateTime?          @default(now()) @db.Timestamp(0)
  Orders           Orders             @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction, map: "Fulfillment_ibfk_1")
  Customer_address Customer_address   @relation(fields: [address_id], references: [address_id], onDelete: Cascade, onUpdate: NoAction, map: "Fulfillment_ibfk_2")

  @@index([address_id], map: "address_id")
  @@index([order_id], map: "order_id")
}

model Inventory {
  inventory_id    Int       @id @default(autoincrement())
  product_id      Int
  available_count Int
  created_at      DateTime? @default(now()) @db.Timestamp(0)
  updated_at      DateTime? @default(now()) @db.Timestamp(0)
  Products        Products  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "Inventory_ibfk_1")

  @@index([product_id], map: "product_id")
}

model OrderItems {
  order_item_id Int       @id @default(autoincrement())
  order_id      Int
  product_id    Int
  count         Int
  amount        Decimal   @db.Decimal(10, 2)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
  Orders        Orders    @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction, map: "OrderItems_ibfk_1")
  Products      Products  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "OrderItems_ibfk_2")

  @@index([order_id], map: "order_id")
  @@index([product_id], map: "product_id")
}

model OrderPayment {
  payment_id   Int                       @id @default(autoincrement())
  order_id     Int
  status       OrderPayment_status
  amount       Decimal                   @db.Decimal(10, 2)
  payment_mode OrderPayment_payment_mode
  created_at   DateTime?                 @default(now()) @db.Timestamp(0)
  updated_at   DateTime?                 @default(now()) @db.Timestamp(0)
  Orders       Orders                    @relation(fields: [order_id], references: [order_id], onDelete: Cascade, onUpdate: NoAction, map: "OrderPayment_ibfk_1")

  @@index([order_id], map: "order_id")
}

model Orders {
  order_id     Int            @id @default(autoincrement())
  customer_id  Int
  amount       Decimal        @db.Decimal(10, 2)
  count        Int
  order_date   DateTime       @db.Date
  created_at   DateTime?      @default(now()) @db.Timestamp(0)
  updated_at   DateTime?      @default(now()) @db.Timestamp(0)
  Fulfillment  Fulfillment[]
  OrderItems   OrderItems[]
  OrderPayment OrderPayment[]
  Customers    Customers      @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction, map: "Orders_ibfk_1")

  @@index([customer_id], map: "customer_id")
}

model ProductImages {
  image_id   Int       @id @default(autoincrement())
  product_id Int
  image_url  String    @db.VarChar(255)
  is_primary Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  Products   Products  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "ProductImages_ibfk_1")

  @@index([product_id], map: "product_id")
}

model Products {
  product_id    Int             @id @default(autoincrement())
  brand         String          @db.VarChar(50)
  category      String          @db.VarChar(50)
  product_name  String          @db.VarChar(50)
  price         Decimal         @db.Decimal(10, 2)
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  updated_at    DateTime?       @default(now()) @db.Timestamp(0)
  description   String?         @db.VarChar(500)
  CartItems     CartItems[]
  Inventory     Inventory[]
  OrderItems    OrderItems[]
  ProductImages ProductImages[]
  Reviews       Reviews[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Reviews {
  review_id   Int       @id @default(autoincrement())
  product_id  Int
  customer_id Int
  rating      Int       @db.TinyInt
  review      String?   @db.VarChar(255)
  comments    String?   @db.Text
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @db.Timestamp(0)
  Products    Products  @relation(fields: [product_id], references: [product_id], onDelete: Cascade, onUpdate: NoAction, map: "Reviews_ibfk_1")
  Customers   Customers @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade, onUpdate: NoAction, map: "Reviews_ibfk_2")

  @@unique([customer_id, product_id], map: "customer_id")
  @@index([product_id], map: "product_id")
}

model Users {
  user_id     Int        @id @default(autoincrement())
  customer_id Int?
  username    String     @unique(map: "username") @db.VarChar(40)
  password    String     @db.VarChar(255)
  created_at  DateTime?  @default(now()) @db.Timestamp(0)
  updated_at  DateTime?  @default(now()) @db.Timestamp(0)
  Customers   Customers? @relation(fields: [customer_id], references: [customer_id], onUpdate: NoAction, map: "Users_ibfk_1")

  @@index([customer_id], map: "customer_id")
}

enum OrderPayment_status {
  Pending
  Paid
  Failed
  Refunded
}

enum Fulfillment_status {
  Pending
  Packed
  Shipped
  Delivered
  Cancelled
}

enum OrderPayment_payment_mode {
  UPI
  Card
  Cash
  NetBanking
}
